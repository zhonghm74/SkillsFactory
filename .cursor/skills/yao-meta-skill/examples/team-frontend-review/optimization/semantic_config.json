      "phrases": [
        "ux regression",
        "behavior regression",
        "pre-merge",
        "quality gate"
      ]
    },
    "frontend_scope": {
      "weight": 0.04,
      "phrases": [
        "react",
        "frontend",
        "ui",
        "component",
        "form"
      ]
    }
  },
  "negative_concepts": {
    "build_ui": {
      "weight": 0.35,
